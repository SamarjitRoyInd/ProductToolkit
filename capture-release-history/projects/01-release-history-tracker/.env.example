# Copy this file to .env and fill in your values. Never commit .env.

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-                       # bot token with channels:history + chat:write
SLACK_RELEASE_CHANNEL_ID=C0123456789        # channel ID, not name (right-click channel > Copy link)
SLACK_DIGEST_CHANNEL_ID=C0123456789         # where to post the "notes are up" digest

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Confluence ---
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_SPACE_KEY=REL
CONFLUENCE_PARENT_PAGE_ID=                  # the parent page under which weekly notes will be created
CONFLUENCE_EMAIL=you@company.com
CONFLUENCE_API_TOKEN=

# --- Run options ---
LOOKBACK_DAYS=7
TIMEZONE=Asia/Kolkata
